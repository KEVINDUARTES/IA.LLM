APP_NAME="CV Scoring System"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=cv_scoring
DB_USERNAME=root
DB_PASSWORD=

# Queue driver: use 'database' for local dev, 'redis' for production
QUEUE_CONNECTION=database

# Redis (optional — use if QUEUE_CONNECTION=redis)
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# OpenAI
OPENAI_API_KEY=gsk_...
OPENAI_MODEL=llama-3.3-70b-versatile